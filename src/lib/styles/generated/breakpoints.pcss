@custom-media --sm (width >= 0px);
@custom-media --sm-l (width >= 530px) and (max-height: 500px);
@custom-media --md (width >= 768px) and (min-height: 501px);
@custom-media --lg (width >= 992px);
@custom-media --xl (width >= 1200px);
@custom-media --xxl (width >= 1400px);
@custom-media --xxxl (width >= 1700px);
